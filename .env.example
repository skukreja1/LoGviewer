# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# App Secret for JWT and Sessions
APP_SECRET="super-secret-key-change-me"

# Initial Admin User (for demo purposes, will be created on first run if not exists)
ADMIN_USER="admin"
ADMIN_PASS="admin123"
